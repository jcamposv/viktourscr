    images: [
      "/gallery/manuel-antonio/main.jpeg",
      "/gallery/manuel-antonio/IMG_1545.jpeg",
    ],
    videos: [
      "/gallery/manuel-antonio/IMG_0720.mp4",
      "/gallery/manuel-antonio/IMG_0721.mp4",
    ],
  },
  {
