---
import { rentACar, booking } from "../../data/site";

const waBase = `https://wa.me/${booking.whatsapp.number}?text=`;
const waReserve = (item: string) =>
  waBase + encodeURIComponent(`Hi Viktours! I'd like to reserve the ${item}. Please send me availability, pickup location and final quote.`);
const waInfo = (item: string) =>
  waBase + encodeURIComponent(`Hi Viktours! I'd like more information about the ${item} rental. Thanks!`);
---

<section class="py-20 lg:py-28 bg-white" id="rent">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-12 lg:mb-16" data-animate>
      <span class="inline-flex items-center gap-2 bg-leaf/15 text-leaf-dark text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13l1.5-4.5A2 2 0 016.4 7h11.2a2 2 0 011.9 1.5L21 13m-18 0v5a1 1 0 001 1h2a1 1 0 001-1v-2h12v2a1 1 0 001 1h2a1 1 0 001-1v-5m-18 0h18M7 17h.01M17 17h.01"/></svg>
        4x4 SUVs · Vans · Full Insurance
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-charcoal">
        {rentACar.headline}
      </h2>
      <p class="mt-5 text-charcoal/55 text-lg font-body max-w-2xl mx-auto">
        {rentACar.subtitle}
      </p>

      <!-- Season legend -->
      <div class="mt-6 inline-flex items-center gap-3 bg-cream rounded-full p-1.5 text-xs">
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-leaf/20 text-leaf-dark font-semibold">
          <span class="w-1.5 h-1.5 rounded-full bg-leaf-dark"></span>
          {rentACar.seasons.low.label}: {rentACar.seasons.low.months}
        </span>
        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-sun/25 text-jungle-dark font-semibold">
          <span class="w-1.5 h-1.5 rounded-full bg-sun-dark"></span>
          {rentACar.seasons.high.label}: {rentACar.seasons.high.months}
        </span>
      </div>
    </div>

    <!-- Vehicles grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 mb-14 lg:mb-20">
      {rentACar.vehicles.map((v) => (
        <article class="bg-cream rounded-3xl overflow-hidden border border-jungle/5 hover:shadow-xl hover:shadow-jungle/10 transition-all" data-animate>
          <div class="relative aspect-[4/3] overflow-hidden bg-jungle/5">
            <img src={v.image} alt={v.name} class="w-full h-full object-cover" loading="lazy" />
            <span class="absolute top-4 left-4 bg-white/95 backdrop-blur text-jungle text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full shadow">
              {v.type}
            </span>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-charcoal text-xl leading-tight mb-3">{v.name}</h3>
            <ul class="flex flex-wrap gap-x-4 gap-y-1.5 mb-5">
              {v.features.map((f) => (
                <li class="flex items-center gap-1.5 text-xs text-charcoal/60">
                  <svg class="w-3 h-3 text-leaf-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>

            {v.priceOnRequest ? (
              <div class="rounded-2xl bg-white p-4 border border-jungle/10">
                <div class="text-[10px] text-charcoal/40 uppercase tracking-widest mb-1">Price on request</div>
                <div class="font-display font-extrabold text-jungle text-lg leading-tight">Contact us for a custom quote</div>
                <div class="text-xs text-charcoal/50 mt-1">Deposit ${v.deposit}</div>
              </div>
            ) : (
              <div class="grid grid-cols-2 gap-2">
                <div class="rounded-2xl bg-leaf/10 p-4">
                  <div class="text-[10px] text-leaf-dark uppercase tracking-widest font-bold mb-1">Low season</div>
                  <div class="flex items-baseline gap-0.5">
                    <span class="text-jungle font-extrabold text-2xl">${v.low}</span>
                    <span class="text-charcoal/50 text-xs">/day</span>
                  </div>
                </div>
                <div class="rounded-2xl bg-sun/20 p-4">
                  <div class="text-[10px] text-jungle-dark uppercase tracking-widest font-bold mb-1">High season</div>
                  <div class="flex items-baseline gap-0.5">
                    <span class="text-jungle font-extrabold text-2xl">${v.high}</span>
                    <span class="text-charcoal/50 text-xs">/day</span>
                  </div>
                </div>
              </div>
            )}

            <div class="text-xs text-charcoal/50 mt-3 flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-jungle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              Security deposit: ${v.deposit}
            </div>

            <div class="mt-5 flex gap-2">
              <a href={waReserve(`${v.name} · ${v.type}`)} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-1.5 bg-leaf hover:bg-leaf-dark text-jungle-dark font-bold rounded-full px-4 py-3 text-sm transition-all shadow-md shadow-leaf/30">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
                Reserve
              </a>
              <a href={waInfo(`${v.name} · ${v.type}`)} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-1 border border-jungle/15 hover:border-jungle text-jungle hover:bg-white font-semibold rounded-full px-4 py-3 text-sm transition-all">
                More info
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Includes & payment -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
      <!-- What's included -->
      <div class="bg-jungle text-white rounded-3xl p-8 lg:p-10 relative overflow-hidden" data-animate>
        <div class="absolute -top-16 -right-16 w-60 h-60 rounded-full bg-leaf/15 blur-3xl pointer-events-none"></div>
        <div class="relative">
          <span class="inline-flex items-center gap-2 bg-leaf/20 text-leaf-light text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full mb-4">
            Every rental includes
          </span>
          <h3 class="font-display text-2xl lg:text-3xl font-extrabold mb-6 leading-tight">Drive worry-free across Costa Rica</h3>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-3">
            {rentACar.includes.map((item) => (
              <li class="flex items-start gap-2.5 text-sm text-white/85">
                <div class="w-5 h-5 rounded-full bg-leaf/25 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-leaf-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Payment -->
      <div class="bg-cream rounded-3xl p-8 lg:p-10 border border-jungle/5" data-animate>
        <span class="inline-flex items-center gap-2 bg-sun/25 text-jungle-dark text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full mb-4">
          Booking & payment
        </span>
        <h3 class="font-display text-2xl lg:text-3xl font-extrabold text-charcoal mb-6 leading-tight">{rentACar.payment.headline}</h3>
        <ol class="space-y-3 mb-6">
          {rentACar.payment.items.map((item, i) => (
            <li class="flex items-start gap-3 text-sm text-charcoal/75">
              <span class="shrink-0 w-6 h-6 rounded-full bg-jungle text-white font-bold text-[11px] flex items-center justify-center mt-0.5">{i + 1}</span>
              <span class="font-body leading-relaxed">{item}</span>
            </li>
          ))}
        </ol>
        <div class="flex flex-wrap gap-3 pt-5 border-t border-charcoal/10">
          {rentACar.extras.map((e) => (
            <span class="inline-flex items-center gap-1.5 bg-white rounded-full px-3 py-1.5 text-xs font-semibold text-charcoal/70 border border-charcoal/5">
              {e.label}
              {e.unit === "free" ? (
                <span class="text-leaf-dark">· Free</span>
              ) : (
                <span class="text-jungle">· ${e.price}/{e.unit}</span>
              )}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
