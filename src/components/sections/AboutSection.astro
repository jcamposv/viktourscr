---
import { about } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-jungle text-white overflow-hidden" id="about">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Image -->
      <div class="relative order-2 lg:order-1" data-animate>
        <div class="relative rounded-3xl overflow-hidden aspect-[4/5] shadow-2xl">
          <img src={about.image} alt="Costa Rica tour guide" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <!-- Floating decorative elements -->
        <div class="absolute -top-4 -right-4 w-20 h-20 bg-sun/30 rounded-2xl -z-10"></div>
        <div class="absolute -bottom-4 -left-4 w-28 h-28 bg-leaf/20 rounded-2xl -z-10"></div>
      </div>

      <!-- Content -->
      <div class="order-1 lg:order-2" data-animate>
        <span class="inline-flex items-center gap-2 bg-sun/20 text-sun text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
          <span>🌴</span> About Us
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight">
          {about.headline}
        </h2>

        {about.paragraphs.map((p) => (
          <p class="mt-5 text-white/70 text-base lg:text-lg leading-relaxed font-body">{p}</p>
        ))}

        <!-- Stats grid -->
        <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-6 pt-8 border-t border-white/10">
          {about.stats.map((s) => (
            <div>
              <span class="block text-3xl font-extrabold text-sun">{s.value}</span>
              <span class="text-white/50 text-xs uppercase tracking-wider mt-1 block">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
