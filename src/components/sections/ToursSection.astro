---
import { tours, booking } from "../../data/site";

const waBase = `https://wa.me/${booking.whatsapp.number}?text=`;
const waReserve = (item: string) =>
  waBase + encodeURIComponent(`Hi Viktours! I'd like to reserve: ${item}. Could you send availability, dates and final price?`);
const waInfo = (item: string) =>
  waBase + encodeURIComponent(`Hi Viktours! I'd like more information about: ${item}. Thanks!`);
---

<section class="py-20 lg:py-28 bg-cream" id="tours">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-10 lg:mb-14" data-animate>
      <span class="inline-flex items-center gap-2 bg-jungle/10 text-jungle text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Volcanoes · Rainforest · Wildlife
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-charcoal">
        {tours.headline}
      </h2>
      <p class="mt-5 text-charcoal/55 text-lg font-body max-w-2xl mx-auto">
        {tours.subtitle}
      </p>
    </div>

    <!-- What's included on every tour -->
    <div class="bg-white rounded-3xl border border-jungle/5 shadow-sm shadow-jungle/5 p-6 lg:p-8 mb-12 lg:mb-16" data-animate>
      <div class="flex flex-col lg:flex-row lg:items-center gap-6">
        <div class="shrink-0 lg:w-52">
          <p class="text-[11px] font-semibold text-leaf uppercase tracking-widest mb-1">Every tour includes</p>
          <p class="font-display font-bold text-xl text-charcoal leading-tight">No surprises. Just Pura Vida.</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-3 flex-1">
          {tours.includes.map((item) => (
            <div class="flex items-center gap-2.5 text-sm">
              <div class="w-5 h-5 rounded-full bg-leaf/20 flex items-center justify-center shrink-0">
                <svg class="w-3 h-3 text-leaf-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-charcoal/75 font-medium">{item}</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Tours compact grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 lg:gap-6">
      {tours.items.map((tour) => (
        <article class="group bg-white rounded-3xl overflow-hidden border border-jungle/5 hover:shadow-xl hover:shadow-jungle/10 hover:-translate-y-1 transition-all duration-300" data-animate>
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src={tour.image} alt={tour.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/50 via-transparent to-transparent"></div>
            <!-- Category -->
            <span class="absolute top-3 left-3 bg-sun/95 text-charcoal font-bold text-[10px] uppercase tracking-widest px-2.5 py-1 rounded-full shadow">
              {tour.category}
            </span>
            <!-- Index -->
            <span class="absolute top-3 right-3 w-8 h-8 rounded-full bg-white/90 backdrop-blur text-jungle text-xs font-extrabold flex items-center justify-center shadow">
              {tour.index}
            </span>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-charcoal text-lg leading-tight mb-1">{tour.title}</h3>
            <p class="text-leaf-dark text-xs font-semibold flex items-center gap-1 mb-3">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {tour.subtitle}
            </p>
            <p class="text-charcoal/60 text-sm leading-relaxed font-body line-clamp-3 mb-4">
              {tour.description}
            </p>
            <div class="pt-4 border-t border-charcoal/10">
              <div class="flex items-baseline justify-between mb-3">
                <div>
                  <span class="text-[10px] text-charcoal/40 uppercase tracking-widest block">From</span>
                  <span class="text-jungle font-extrabold text-xl">${tour.price}<span class="text-charcoal/40 font-normal text-xs">/pp</span></span>
                </div>
              </div>
              <div class="flex gap-2">
                <a href={waReserve(tour.title)} target="_blank" rel="noopener" class="flex-1 inline-flex items-center justify-center gap-1.5 bg-leaf hover:bg-leaf-dark text-jungle-dark font-bold text-sm rounded-full px-3 py-2 transition-all shadow-md shadow-leaf/25">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
                  Reserve
                </a>
                <a href={waInfo(tour.title)} target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-1 border border-jungle/15 hover:border-jungle text-jungle hover:bg-cream font-semibold text-sm rounded-full px-3 py-2 transition-all">
                  Info
                </a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Family / Group Tours callout -->
    <div class="mt-16 lg:mt-24 relative overflow-hidden rounded-3xl bg-jungle text-white" data-animate>
      <!-- Decorative blobs -->
      <div class="absolute -top-20 -right-20 w-80 h-80 rounded-full bg-leaf/20 blur-3xl pointer-events-none"></div>
      <div class="absolute -bottom-24 -left-16 w-80 h-80 rounded-full bg-sea/15 blur-3xl pointer-events-none"></div>

      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch">
        <!-- Content -->
        <div class="p-8 lg:p-14">
          <span class="inline-flex items-center gap-2 bg-sun/20 text-sun text-xs font-bold uppercase tracking-wider px-3 py-1.5 rounded-full mb-5">
            ★ Featured · Weekly Departures
          </span>
          <h3 class="font-display text-3xl lg:text-4xl font-extrabold leading-tight mb-4">
            {tours.group.title}
          </h3>
          <p class="text-white/70 leading-relaxed font-body mb-7 max-w-lg">
            {tours.group.description}
          </p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 mb-8">
            {tours.group.features.map((f) => (
              <li class="flex items-center gap-2.5 text-sm text-white/85">
                <div class="w-5 h-5 rounded-full bg-leaf/25 flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 text-leaf-light" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                {f}
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-3">
            <a href={waReserve(tours.group.title)} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-leaf hover:bg-leaf-dark text-jungle-dark font-bold rounded-full px-6 py-3.5 text-sm transition-all shadow-lg shadow-leaf/30">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347"/></svg>
              Reserve via WhatsApp
            </a>
            <a href={waInfo(tours.group.title)} target="_blank" rel="noopener" class="inline-flex items-center gap-2 border-2 border-white/25 hover:bg-white/10 text-white font-semibold rounded-full px-6 py-3.5 text-sm transition-all">
              More info
            </a>
          </div>
        </div>

        <!-- Image -->
        <div class="relative min-h-[16rem] lg:min-h-[28rem]">
          <img src="https://images.unsplash.com/photo-1501555088652-021faa106b9b?auto=format&fit=crop&w=1200&q=80" alt="Family tour" class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-r from-jungle/80 via-jungle/20 to-transparent lg:bg-gradient-to-l"></div>
        </div>
      </div>
    </div>
  </div>
</section>
