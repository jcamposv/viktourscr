---
import { tours } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-cream" id="tours">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="max-w-3xl mx-auto text-center mb-16 lg:mb-24" data-animate>
      <span class="inline-flex items-center gap-2 bg-jungle/10 text-jungle text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Volcanoes, Rainforest & Wildlife
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-charcoal">
        {tours.headline}
      </h2>
      <p class="mt-5 text-charcoal/55 text-lg font-body max-w-2xl mx-auto">
        {tours.subtitle}
      </p>
    </div>

    <!-- Tours - alternating zig-zag layout -->
    <div class="space-y-16 lg:space-y-24">
      {tours.items.map((tour, i) => (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center" data-animate>
          <!-- Image -->
          <div class={`relative ${i % 2 !== 0 ? "lg:order-2" : ""}`}>
            <div class="relative rounded-2xl lg:rounded-3xl overflow-hidden aspect-[4/3] shadow-xl shadow-jungle/10">
              <img src={tour.image} alt={tour.title} class="w-full h-full object-cover" loading="lazy" />
              <!-- Category badge -->
              <div class="absolute top-4 left-4 bg-sun text-charcoal font-bold text-xs uppercase tracking-wider px-4 py-2 rounded-full shadow-lg">
                {tour.category}
              </div>
            </div>
            <!-- Price floating card -->
            <div class={`absolute -bottom-6 bg-white rounded-2xl shadow-xl shadow-jungle/15 p-5 flex items-center gap-5 max-w-sm ${i % 2 !== 0 ? "right-6 lg:right-8 lg:left-auto" : "left-6 lg:left-8 lg:right-auto"}`}>
              <div>
                <span class="text-[11px] text-charcoal/40 uppercase tracking-widest block">From</span>
                <div class="flex items-baseline gap-1">
                  <span class="text-jungle font-extrabold text-3xl">${tour.price}</span>
                  <span class="text-charcoal/50 text-sm font-medium">/ pp</span>
                </div>
              </div>
              <div class="w-px h-10 bg-charcoal/10"></div>
              <div>
                <span class="text-[11px] text-charcoal/40 uppercase tracking-widest block">Duration</span>
                <span class="text-charcoal font-semibold text-sm flex items-center gap-1.5">
                  <svg class="w-3.5 h-3.5 text-jungle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  {tour.duration.split(" · ")[0]}
                </span>
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class={`pt-8 lg:pt-0 ${i % 2 !== 0 ? "lg:order-1" : ""}`}>
            <div class="flex items-center gap-4 mb-4">
              <span class="text-6xl font-display font-extrabold text-jungle/10 leading-none">{tour.index}</span>
              <div>
                <h3 class="text-2xl lg:text-3xl font-bold text-charcoal leading-tight">{tour.title}</h3>
                <p class="text-leaf text-sm font-semibold flex items-center gap-1.5 mt-1">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  {tour.subtitle}
                </p>
              </div>
            </div>

            <p class="text-charcoal/60 text-base lg:text-lg leading-relaxed font-body mb-6">
              {tour.description}
            </p>

            <!-- Meta info -->
            <div class="flex flex-wrap gap-5 mb-6">
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-5 h-5 text-jungle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="font-medium text-charcoal/70">{tour.duration}</span>
              </div>
              <div class="flex items-center gap-2 text-sm">
                <svg class="w-5 h-5 text-jungle" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                <span class="font-medium text-charcoal/70">{tour.groupSize}</span>
              </div>
            </div>

            <!-- What's included -->
            <div class="bg-white rounded-2xl p-5 mb-6 border border-charcoal/5">
              <p class="text-xs font-semibold text-leaf uppercase tracking-widest mb-3">What's Included</p>
              <ul class="space-y-2.5">
                {tour.highlights.map((item) => (
                  <li class="flex items-center gap-3 text-sm text-charcoal/75 font-body">
                    <div class="w-5 h-5 rounded-full bg-leaf/20 flex items-center justify-center shrink-0">
                      <svg class="w-3 h-3 text-leaf" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                    {item}
                  </li>
                ))}
              </ul>
            </div>

            <button data-booking class="inline-flex items-center gap-2 bg-jungle hover:bg-jungle-dark text-white font-semibold rounded-full px-7 py-3.5 text-sm transition-all shadow-lg shadow-jungle/20 cursor-pointer">
              Book This Tour
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </button>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom trust banner -->
    <div class="mt-20 lg:mt-28 bg-jungle rounded-3xl p-8 lg:p-12 text-center" data-animate>
      <span class="inline-flex items-center gap-2 bg-sun/20 text-sun text-xs font-semibold px-3 py-1 rounded-full mb-4 uppercase tracking-wider">
        The Viktours Promise
      </span>
      <h3 class="text-2xl lg:text-3xl font-bold text-white mb-3">Every Tour Includes</h3>
      <p class="text-white/60 font-body max-w-2xl mx-auto mb-8">
        No hidden fees, no tourist traps. Just authentic Costa Rica experiences with certified local guides.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-3xl mx-auto">
        <div class="text-center">
          <svg class="w-8 h-8 mx-auto text-sun mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
          <span class="block text-white font-semibold text-sm">Hotel Pickup</span>
          <span class="text-white/50 text-xs mt-1 block">Round-trip included</span>
        </div>
        <div class="text-center">
          <svg class="w-8 h-8 mx-auto text-sun mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span class="block text-white font-semibold text-sm">Small Groups</span>
          <span class="text-white/50 text-xs mt-1 block">Max 12 per tour</span>
        </div>
        <div class="text-center">
          <svg class="w-8 h-8 mx-auto text-sun mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          <span class="block text-white font-semibold text-sm">ICT Certified</span>
          <span class="text-white/50 text-xs mt-1 block">Fully insured</span>
        </div>
        <div class="text-center">
          <svg class="w-8 h-8 mx-auto text-sun mb-2" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <span class="block text-white font-semibold text-sm">Free Cancellation</span>
          <span class="text-white/50 text-xs mt-1 block">No deposit required</span>
        </div>
      </div>
    </div>
  </div>
</section>
