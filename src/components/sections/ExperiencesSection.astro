---
import { experiences } from "../../data/site";

const icons: Record<string, string> = {
  car: "M3 13l1.5-4.5A2 2 0 016.4 7h11.2a2 2 0 011.9 1.5L21 13m-18 0v5a1 1 0 001 1h2a1 1 0 001-1v-2h12v2a1 1 0 001 1h2a1 1 0 001-1v-5m-18 0h18M7 17h.01M17 17h.01",
  transfer: "M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4",
  group: "M17 20h5v-2a4 4 0 00-3-3.87M9 20H4v-2a4 4 0 013-3.87m6-5a4 4 0 11-8 0 4 4 0 018 0zm6 3a3 3 0 11-6 0 3 3 0 016 0z",
};
---

<section class="py-20 lg:py-28 bg-white" id="experiences">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl mx-auto text-center mb-14 lg:mb-20" data-animate>
      <span class="inline-flex items-center gap-2 bg-sun/20 text-charcoal text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Top-Rated Experiences
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight text-charcoal">
        {experiences.headline}
      </h2>
      <p class="mt-4 text-charcoal/60 text-lg font-body max-w-2xl mx-auto">{experiences.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {experiences.items.map((exp) => (
        <article class="tour-card bg-white rounded-3xl overflow-hidden">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src={exp.image} alt={exp.title} class="w-full h-full object-cover" loading="lazy" />
            <div class="absolute top-4 left-4 w-12 h-12 bg-white/95 backdrop-blur rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-jungle" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d={icons[exp.icon]} /></svg>
            </div>
          </div>
          <div class="p-6 lg:p-7">
            <div class="flex items-center gap-2 text-xs text-charcoal/50 uppercase tracking-wider font-semibold mb-2">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              {exp.duration}
            </div>
            <h3 class="text-xl font-bold text-charcoal mb-2">{exp.title}</h3>
            <p class="text-charcoal/60 text-sm leading-relaxed font-body mb-5">{exp.description}</p>
            <div class="flex items-baseline justify-between pt-4 border-t border-charcoal/10">
              <div>
                <span class="text-xs text-charcoal/40 uppercase tracking-wider block">from</span>
                <span class="text-jungle font-extrabold text-2xl">${exp.price}<span class="text-charcoal/40 font-normal text-sm">/{exp.unit ?? "pp"}</span></span>
              </div>
              <button data-booking class="inline-flex items-center gap-1.5 text-jungle hover:text-jungle-dark font-semibold text-sm cursor-pointer">
                Book Now
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
