---
import { transfers } from "../../data/site";
---

<section class="py-20 lg:py-28 bg-jungle text-white relative overflow-hidden" id="transfers">
  <!-- Decorative background -->
  <div class="absolute inset-0 opacity-10 pointer-events-none">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-leaf blur-3xl"></div>
    <div class="absolute -bottom-32 -left-24 w-96 h-96 rounded-full bg-sea blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16 items-start">
      <!-- Left: Intro -->
      <div class="lg:col-span-2" data-animate>
        <span class="inline-flex items-center gap-2 bg-leaf/20 text-leaf-light text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4M16 17H4m0 0l4 4m-4-4l4-4"/></svg>
          Airport Transfers
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight leading-tight">
          {transfers.headline}
        </h2>
        <p class="mt-5 text-white/70 text-base lg:text-lg leading-relaxed font-body">
          {transfers.subtitle}
        </p>
        <div class="mt-8 p-5 bg-white/5 border border-white/10 rounded-2xl">
          <p class="text-sun font-semibold italic leading-relaxed">
            "{transfers.note}"
          </p>
        </div>
        <a
          href="https://wa.me/50689537777"
          target="_blank"
          rel="noopener"
          class="mt-8 inline-flex items-center gap-2 bg-leaf hover:bg-leaf-dark text-jungle-dark font-bold px-6 py-3.5 rounded-full transition-colors"
        >
          Book a Transfer
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>

      <!-- Right: Price list -->
      <div class="lg:col-span-3 space-y-3" data-animate>
        {transfers.routes.map((route) => (
          <div class="group flex items-center justify-between gap-4 bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl px-5 py-4 lg:px-7 lg:py-5 transition-colors">
            <div class="flex items-center gap-4 min-w-0">
              <div class="shrink-0 w-10 h-10 lg:w-12 lg:h-12 rounded-xl bg-leaf/20 flex items-center justify-center">
                <svg class="w-5 h-5 lg:w-6 lg:h-6 text-leaf-light" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div class="min-w-0">
                <div class="text-xs text-white/50 uppercase tracking-wider font-semibold">{route.from} →</div>
                <div class="text-lg lg:text-xl font-bold truncate">{route.to}</div>
              </div>
            </div>
            <div class="shrink-0 text-right">
              <span class="text-sun font-extrabold text-2xl lg:text-3xl">${route.price}</span>
            </div>
          </div>
        ))}
        <p class="text-white/40 text-xs font-body pt-2">Prices per transfer. Contact us for return, custom or multi-stop routes.</p>
      </div>
    </div>
  </div>
</section>
