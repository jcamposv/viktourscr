---
import { navigation, siteConfig, footer } from "../../data/site";
import MobileMenu from "./MobileMenu";
---

<header class="fixed top-0 left-0 right-0 z-50 vk-header" id="top">
    <!-- Top utility bar -->
    <div class="vk-topbar bg-jungle-dark text-white/80 text-xs">
        <div
            class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-9 flex items-center justify-between gap-4"
        >
            <div class="hidden sm:flex items-center gap-5">
                <a
                    href={`tel:${footer.contact.phone.replace(/\D/g, "")}`}
                    class="flex items-center gap-1.5 hover:text-leaf-light transition-colors"
                >
                    <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3 5a2 2 0 012-2h3l2 5-2.5 1.5a11 11 0 005 5L12 12l5 2v3a2 2 0 01-2 2h-1C7.82 19 5 16.18 5 8V7 "
                        ></path></svg
                    >
                    {footer.contact.phone}
                </a>
                <a
                    href={`mailto:${footer.contact.email}`}
                    class="hidden md:flex items-center gap-1.5 hover:text-leaf-light transition-colors"
                >
                    <svg
                        class="w-3.5 h-3.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                        ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M3 8l9 6 9-6M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path></svg
                    >
                    {footer.contact.email}
                </a>
            </div>
            <div class="flex items-center gap-3 ml-auto">
                <span
                    class="hidden md:inline-flex items-center gap-1.5 text-leaf-light"
                >
                    <span class="w-1.5 h-1.5 bg-leaf rounded-full animate-pulse"
                    ></span>
                    Open today · 7 AM – 9 PM
                </span>
                <span class="hidden md:block w-px h-4 bg-white/15"></span>
                {
                    footer.socials.slice(0, 3).map((s) => (
                        <a
                            href={s.href}
                            aria-label={s.label}
                            class="text-white/60 hover:text-leaf-light transition-colors text-[11px] font-semibold uppercase tracking-wider"
                        >
                            {s.label}
                        </a>
                    ))
                }
            </div>
        </div>
    </div>

    <div class="vk-mainbar">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-3 lg:pt-4">
            <div
                class="vk-pill bg-white/95 backdrop-blur-md rounded-full shadow-lg shadow-jungle/10 border border-jungle/5 flex items-center justify-between pl-3 pr-3 lg:pl-4 lg:pr-2 h-16 lg:h-[72px]"
            >
                <!-- Logo inside a circular ring -->
                <a
                    href="/"
                    class="flex items-center gap-3 shrink-0 relative z-50"
                >
                    <span
                        class="relative flex items-center justify-center w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-gradient-to-br from-leaf-light to-sea ring-2 ring-white shadow-md"
                    >
                        <img
                            src="/logo.png"
                            alt={siteConfig.name}
                            class="w-10 h-10 lg:w-12 lg:h-12 object-contain"
                        />
                    </span>
                    <span class="hidden sm:flex flex-col leading-none">
                        <span
                            class="font-display font-extrabold text-jungle text-lg tracking-tight"
                            >Viktours</span
                        >
                        <span
                            class="text-[10px] uppercase tracking-[0.18em] text-leaf font-semibold"
                            >Pura Vida CR</span
                        >
                    </span>
                </a>

                <!-- Desktop nav -->
                <nav
                    class="hidden lg:flex items-center gap-1"
                    aria-label="Main navigation"
                >
                    {
                        navigation.map((item) => (
                            <a
                                href={item.href}
                                class="vk-nav-link relative px-3.5 py-2 text-sm font-semibold text-charcoal/70 hover:text-jungle transition-colors rounded-full"
                            >
                                {item.label}
                            </a>
                        ))
                    }
                </nav>

                <!-- CTA -->
                <div class="hidden lg:flex items-center gap-2">
                    <a
                        href="https://wa.me/50689537777"
                        target="_blank"
                        rel="noopener"
                        aria-label="WhatsApp"
                        class="flex items-center justify-center w-10 h-10 rounded-full bg-leaf/15 text-leaf-dark hover:bg-leaf hover:text-white transition-all"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                            ></path></svg
                        >
                    </a>
                    <button
                        data-booking
                        class="inline-flex items-center gap-2 bg-leaf hover:bg-leaf-dark text-jungle-dark font-bold rounded-full px-5 py-2.5 text-sm transition-all shadow-md shadow-leaf/30 cursor-pointer"
                    >
                        Plan My Trip
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            viewBox="0 0 24 24"
                            ><path d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                        >
                    </button>
                </div>

                <MobileMenu client:load />
            </div>
        </div>
    </div>
</header>

<script>
    const header = document.querySelector("header");
    const update = () => {
        if (!header) return;
        if (window.scrollY > 40) header.classList.add("header-scrolled");
        else header.classList.remove("header-scrolled");
    };
    window.addEventListener("scroll", update, { passive: true });
    update();
</script>

<style>
    .vk-header {
        transition: transform 0.35s ease;
    }
    .vk-topbar {
        max-height: 2.25rem;
        overflow: hidden;
        transition:
            max-height 0.35s ease,
            opacity 0.25s ease;
    }
    .vk-mainbar {
        transition: padding 0.3s ease;
    }
    .vk-pill {
        transition:
            box-shadow 0.3s ease,
            transform 0.3s ease,
            border-radius 0.3s ease;
    }

    /* Scrolled state: hide top bar and tighten main bar */
    :global(header.header-scrolled) .vk-topbar {
        max-height: 0;
        opacity: 0;
    }
    :global(header.header-scrolled) .vk-pill {
        box-shadow: 0 10px 30px -8px rgba(15, 61, 46, 0.18);
    }

    @media (max-width: 1023px) {
        .vk-topbar {
            max-height: 2.25rem;
        }
    }
</style>
