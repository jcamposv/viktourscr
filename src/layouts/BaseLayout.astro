---
import { siteConfig, booking, footer } from "../data/site";
import BookingModal from "../components/booking/BookingModal";
import "../styles/global.css";

interface Props { title?: string; description?: string; }
const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
const ogImage = `${siteConfig.url}/logo.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Costa Rica tours, rent a car Costa Rica, airport transfers Costa Rica, Arenal volcano tour, Monteverde tour, Manuel Antonio tour, Rio Celeste, Tortuguero, Poás volcano, private transfers, Liberia airport, SJO airport, 4x4 rental Costa Rica, day tours Costa Rica, Nicaragua tours, Guatemala tours, family tours, group tours" />
    <meta name="author" content={siteConfig.name} />
    <link rel="canonical" href={siteConfig.url} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="CR-G" />
    <meta name="geo.placename" content="Guanacaste, Costa Rica" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteConfig.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TravelAgency",
      "name": siteConfig.name,
      "description": siteConfig.description,
      "url": siteConfig.url,
      "logo": ogImage,
      "image": ogImage,
      "telephone": footer.contact.phone,
      "email": footer.contact.email,
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Liberia",
        "addressRegion": "Guanacaste",
        "addressCountry": "CR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "10.5933",
        "longitude": "-85.5444"
      },
      "openingHours": "Mo-Su 07:00-21:00",
      "priceRange": "$57 - $450 USD",
      "sameAs": [
        "https://instagram.com/viktourscr",
        "https://facebook.com/viktourscr"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Costa Rica Travel Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Arenal Volcano · La Fortuna", "description": "Full day tour to Arenal Volcano with hot springs" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Monteverde Cloud Forest", "description": "Explore the famous cloud forest reserve" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Manuel Antonio National Park", "description": "Beaches and wildlife at Manuel Antonio" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Río Celeste", "description": "Discover the mystical turquoise river" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Tortuguero Canals", "description": "Caribbean canal boat tour" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rent a Car", "description": "4x4 vehicles from $57/day" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Airport Transfers", "description": "Private transfers from SJO and LIR airports" } }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "150",
        "bestRating": "5"
      }
    })} />
  </head>
  <body class="min-h-screen">
    <slot />
    <BookingModal client:load whatsappNumber={booking.whatsapp.number} />

    <script>
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const bookingBtn = target.closest("[data-booking]");
        if (bookingBtn) { e.preventDefault(); window.dispatchEvent(new CustomEvent("open-booking")); return; }
        const link = target.closest('a[href="#top"]') as HTMLAnchorElement | null;
        if (link) { e.preventDefault(); window.scrollTo({ top: 0, behavior: "smooth" }); }
      });

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add("visible"); });
      }, { threshold: 0.1 });
      document.querySelectorAll("[data-animate]").forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
